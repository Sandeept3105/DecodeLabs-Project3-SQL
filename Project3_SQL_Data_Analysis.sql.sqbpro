<?xml version="1.0" encoding="UTF-8"?><sqlb_project><db path="C:/Users/dell/Documents/Internship/DataAnalytics.db" readonly="0" foreign_keys="1" case_sensitive_like="0" temp_store="0" wal_autocheckpoint="1000" synchronous="2"/><attached/><window><main_tabs open="structure browser pragmas query" current="3"/></window><tab_structure><column_width id="0" width="300"/><column_width id="1" width="0"/><column_width id="2" width="100"/><column_width id="3" width="1853"/><column_width id="4" width="0"/><expanded_item id="0" parent="1"/><expanded_item id="0" parent="0"/><expanded_item id="1" parent="1"/><expanded_item id="2" parent="1"/><expanded_item id="3" parent="1"/></tab_structure><tab_browse><table title="Orders" custom_title="0" dock_id="1" table="4,6:mainOrders"/><dock_state state="000000ff00000000fd00000001000000020000043c000002b6fc0100000001fb000000160064006f0063006b00420072006f007700730065003101000000000000043c0000012d00ffffff000002580000000000000004000000040000000800000008fc00000000"/><default_encoding codec=""/><browse_table_settings><table schema="main" name="Orders" show_row_id="0" encoding="" plot_x_axis="" unlock_view_pk="_rowid_" freeze_columns="0"><sort/><column_widths><column index="1" value="78"/><column index="2" value="85"/><column index="3" value="75"/><column index="4" value="62"/><column index="5" value="56"/><column index="6" value="59"/><column index="7" value="101"/><column index="8" value="99"/><column index="9" value="78"/><column index="11" value="77"/><column index="12" value="78"/><column index="13" value="91"/><column index="14" value="64"/></column_widths><filter_values/><conditional_formats/><row_id_formats/><display_formats/><hidden_columns/><plot_y_axes/><global_filter/></table></browse_table_settings></tab_browse><tab_sql><sql name="SQL 1">-- Query 1: Display all records
SELECT * FROM Orders;

-- Query 2: Display selected columns
SELECT OrderID, Product, TotalPrice
FROM Orders;

-- Query 3: Display delivered orders
SELECT *
FROM Orders
WHERE OrderStatus = 'Delivered';

-- Query 4: Highest value orders
SELECT OrderID, Product, TotalPrice
FROM Orders
ORDER BY TotalPrice DESC;

-- Query 5: Lowest value orders
SELECT OrderID, Product, TotalPrice
FROM Orders
ORDER BY TotalPrice ASC;

-- Query 6: Number of orders by product
SELECT Product,
COUNT(*) AS Total_Orders
FROM Orders
GROUP BY Product;

-- Query 7: Revenue by product
SELECT Product,
SUM(TotalPrice) AS Total_Revenue
FROM Orders
GROUP BY Product;

-- Query 8: Average order value by product
SELECT Product,
AVG(TotalPrice) AS Average_Order_Value
FROM Orders
GROUP BY Product;

-- Query 9: Orders by payment method
SELECT PaymentMethod,
COUNT(*) AS Number_of_Orders
FROM Orders
GROUP BY PaymentMethod;

-- Query 10: Orders by status
SELECT OrderStatus,
COUNT(*) AS Total_Orders
FROM Orders
GROUP BY OrderStatus;

-- Query 11: Overall summary
SELECT
COUNT(*) AS Total_Orders,
SUM(TotalPrice) AS Total_Revenue,
AVG(TotalPrice) AS Average_Order_Value
FROM Orders;

-- Query 12: Top 5 customers by spending
SELECT CustomerID,
SUM(TotalPrice) AS Total_Spent
FROM Orders
GROUP BY CustomerID
ORDER BY Total_Spent DESC
LIMIT 5;</sql><current_tab id="0"/></tab_sql></sqlb_project>
